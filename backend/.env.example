# ====================================================================================
# SafePassage Backend Environment Configuration
# 
# Copy this file to .env and fill in the values for your environment.
# For Railway deployment, use the values specified in RAILWAY_DEPLOYMENT.md
# ====================================================================================

# CORE CONFIGURATION
# ==================
APP_CONFIG=development
# Options: 'development' (debug mode, reload on file change) or 'production' (optimized)
# For Railway: APP_CONFIG=production

# DATABASE CONNECTION
# ===================
# Local PostgreSQL example:
#   postgresql://user:password@localhost:5432/safepassage
# Railway auto-provides: ${{DATABASE_URL}} variable (set to this in Railway console)
SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost:5432/safepassage

# CRITICAL: OpenAI API Key (Required for Itinerary Risk Analysis - PREVENTION Pillar)
# ==================================================================================
# Obtain from: https://platform.openai.com/api-keys
# Format: sk-proj-xxxx... or sk-xxxx...
# If missing: Itinerary upload will fail with 401 error
OPENAI_API_KEY=sk-proj-your-api-key-here

# Optional: Alternative LLM Provider
ANTHROPIC_API_KEY=

# FRONTEND CORS CONFIGURATION
# ============================
# Comma-separated list of allowed frontend origins
# 
# LOCAL DEVELOPMENT:
#   http://localhost:8081,http://localhost:19006
#
# RAILWAY PRODUCTION:
#   https://your-frontend.railway.app,https://your-domain.com
#
# NOTE: Must match exact URLs that appear in browser. Include https:// scheme.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
CORS_ALLOW_CREDENTIALS=0

# OPTIONAL: Supabase Integration (Optional - for future updates)
# ================================================================
SUPABASE_URL=
SUPABASE_KEY=

# OPTIONAL: SMS Alerts via Twilio (Currently Stubbed)
# ====================================================
# Only enable if you've implemented SMS notification logic
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OPTIONAL: Emergency Telegram Bot (Currently Stubbed)
# =====================================================
# Set TELEGRAM_BOT_ENABLED=1 to enable emergency contact alerts via Telegram
# Obtain bot token from BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=0
TELEGRAM_POLL_INTERVAL_SECONDS=2

# OPTIONAL: Heartbeat Monitoring Scheduler (CURE Pillar)
# ========================================================
# Default: Disabled (ENABLE_HEARTBEAT_SCHEDULER=0)
# 
# For Railway multi-instance, keep disabled and use Railway Cron job instead.
# For single-instance traditional VPS, enable to run monitoring background task.
#
# NOTE: APScheduler runs in-process. Multiple instances = duplicate alerts.
ENABLE_HEARTBEAT_SCHEDULER=0
HEARTBEAT_WATCHDOG_INTERVAL_MINUTES=5
HEARTBEAT_WATCHDOG_KEY=your-secret-key-for-internal-endpoints
HEARTBEAT_FORCE_STAGE_1_TEST_MODE=0

# PORT (Set by Railway, Override Locally if Needed)
# ==================================================
# Railway sets PORT automatically; only set this if running container locally
# PORT=5000
