APP_CONFIG=development
FLASK_ENV=development
FLASK_DEBUG=0

# Use Supabase/Postgres in production if available, else sqlite fallback
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://user:password@host:5432/dbname
SQLALCHEMY_DATABASE_URI=sqlite:////app/data/safepassage.db

SUPABASE_URL=
SUPABASE_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

ENABLE_HEARTBEAT_SCHEDULER=0
HEARTBEAT_WATCHDOG_INTERVAL_MINUTES=5
HEARTBEAT_WATCHDOG_KEY=

CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000
CORS_ALLOW_CREDENTIALS=0